QDRANT_URL ?= 
QDRANT_COLLECTION_NAME ?= evaluation
EMBEDDINGS_DENSE_URL ?= 
EMBEDDINGS_DENSE_MODEL ?= Qwen/Qwen3-Embedding-0.6B
API_KEY ?= dev-api-key
RERANKER_URL ?= 
QDRANT_DENSE_VECTOR_NAME ?= dense
QDRANT_SPARSE_VECTOR_NAME ?= sparse
PORT ?= 8000

REQUIRED_VARS := QDRANT_URL EMBEDDINGS_DENSE_URL RERANKER_URL

.PHONY: run check-env

check-env:
	@$(foreach var,$(REQUIRED_VARS),$(if $($(var)),,$(error $(var) is required)))

run: check-env
	QDRANT_URL=$(QDRANT_URL) \
	QDRANT_COLLECTION_NAME=$(QDRANT_COLLECTION_NAME) \
	EMBEDDINGS_DENSE_URL=$(EMBEDDINGS_DENSE_URL) \
	EMBEDDINGS_DENSE_MODEL=$(EMBEDDINGS_DENSE_MODEL) \
	API_KEY=$(API_KEY) \
	RERANKER_URL=$(RERANKER_URL) \
	QDRANT_DENSE_VECTOR_NAME=$(QDRANT_DENSE_VECTOR_NAME) \
	QDRANT_SPARSE_VECTOR_NAME=$(QDRANT_SPARSE_VECTOR_NAME) \
	PORT=$(PORT) \
	uv run main.py
